# ─── OPCIÓN A: Base de datos en la nube (Neon, Supabase, Railway) ───────────
# Copia el connection string de tu proveedor aquí:
# DATABASE_URL=postgresql://usuario:contraseña@host/nombre_db?sslmode=require

# ─── OPCIÓN B: PostgreSQL local (desarrollo) ────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=gorditas_db

# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Genera una clave fuerte en producción: openssl rand -hex 32
JWT_SECRET=cambia_esta_clave_en_produccion
JWT_EXPIRES_IN=8h
